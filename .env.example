# Application
APP_NAME=星图智顾
APP_VERSION=0.1.0
DEBUG=true

# Active LLM provider: deepseek | qwen | kimi
ACTIVE_LLM=deepseek

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# Qwen / DashScope OpenAI-compatible endpoint
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Kimi / Moonshot OpenAI-compatible endpoint
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-32k

# Database
DATABASE_URL=sqlite+aiosqlite:///./starmap.db

# Redis
REDIS_URL=redis://localhost:6379/0

# Cache TTL, seconds
CACHE_QUOTE_TTL=600
CACHE_STOCK_QUOTE_TTL=30
CACHE_FUND_ESTIMATE_TTL=20
CACHE_FUND_HOLDING_TTL=604800
CACHE_RANK_TTL=3600
CACHE_FUND_LIST_TTL=86400

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
